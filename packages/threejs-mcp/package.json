{
  "name": "@indiavenkatesh/mcp-threejs",
  "version": "1.1.0",
  "description": "MCP server exposing all Three.js features as tools, with daily auto-synced API docs",
  "type": "module",
  "bin": {
    "mcp-threejs": "./src/index.js"
  },
  "main": "./src/index.js",
  "files": [
    "src/",
    "docs/README.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "prepublishOnly": "node --input-type=module <<< 'import \"./src/index.js\"' --check 2>/dev/null || true"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "zod": "^3.23.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "threejs",
    "three.js",
    "3d",
    "webgl",
    "animation",
    "claude",
    "anthropic"
  ],
  "author": "indiavenkatesh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/indiavenkatesh/mcp.git",
    "directory": "packages/threejs-mcp"
  },
  "homepage": "https://github.com/indiavenkatesh/mcp/tree/main/packages/threejs-mcp#readme",
  "bugs": {
    "url": "https://github.com/indiavenkatesh/mcp/issues"
  }
}
